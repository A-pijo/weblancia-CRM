# Weblancia — Production Configuration (Hostinger)
# Copy to .env.local for local dev
# Set ALL variables below in Hostinger Node.js env panel

# Site URL
SITE_URL=https://app.weblancia.com

# ── REQUIRED: MySQL Database (Hostinger) ──
# On Hostinger shared hosting, use 127.0.0.1 (not localhost) to force IPv4 TCP.
# For external connections, use srv1794.hstgr.io (requires MySQL remote access grant).
DB_HOST=127.0.0.1
DB_USER=u539468682_weblancia
DB_PASSWORD=change-this-to-your-mysql-password
DB_NAME=u539468682_weblancia
DB_PORT=3306

# Prisma DATABASE_URL (auto-constructed from DB_* vars by scripts/deploy.mjs)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://u539468682_weblancia:password@127.0.0.1:3306/u539468682_weblancia"

# ── REQUIRED: Authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# ── Optional: SMTP (contact form emails) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=hello@weblancia.ma
NOTIFICATION_EMAIL=hello@weblancia.ma

# ── Optional: Analytics / Integrations ──
WHATSAPP_NUMBER=+212XXXXXXXXX
WHATSAPP_ENABLED=false
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxx
CLARITY_ID=xxxxxxxxxx
