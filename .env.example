# Weblancia — Production Configuration (Supabase PostgreSQL)
# Copy to .env.local for local dev
# Set ALL variables below in your hosting Node.js env panel

# Site URL
SITE_URL=https://app.weblancia.com

# ── REQUIRED: PostgreSQL Database (Supabase) ──
# Get these from your Supabase project dashboard → Project Settings → Database
DB_HOST=db.xxxxxxxxxxxxxx.supabase.co
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_NAME=postgres
DB_PORT=5432

# DATABASE_URL (direct connection — for Prisma runtime and migrations)
# Format: postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/DATABASE
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres"

# DIRECT_URL (same as DATABASE_URL by default — override for pooler session mode)
# When using Supabase pooler: postgresql://USER:PASSWORD@PROJECT_REF.pooler.supabase.com:5432/DATABASE
DIRECT_URL="postgresql://postgres:password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres"

# Legacy: DATABASE_URL is auto-constructed from DB_* vars by scripts/deploy.mjs
# for backward compatibility during build if DATABASE_URL is not set directly.

# ── REQUIRED: Authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# ── Optional: AI Auto-Publishing ──
# AI_PROVIDER: "gemini" (default, free) or "openai"
# Switching requires only changing this one variable — no code changes.
AI_PROVIDER=gemini
# AI_LANGUAGE: "fr" (default), "en", or "ar"
AI_LANGUAGE=fr

# Get your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get your OpenAI API key from https://platform.openai.com/api-keys
# Only needed if AI_PROVIDER=openai
OPENAI_API_KEY=

# CRON_SECRET: a random string used to authenticate cron job calls
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=change-this-to-a-random-64-char-string

# ── Optional: Supabase Client (for Storage, Auth, Realtime) ──
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ── Optional: SMTP (contact form emails) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=hello@weblancia.ma
NOTIFICATION_EMAIL=hello@weblancia.ma

# ── Optional: Analytics / Integrations ──
WHATSAPP_NUMBER=+212XXXXXXXXX
WHATSAPP_ENABLED=false
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxx
CLARITY_ID=xxxxxxxxxx
