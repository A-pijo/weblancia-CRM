# Weblancia — Hostinger Production Configuration
# Copy this file to .env.local for local dev
# Set these variables in Hostinger's Node.js env panel for production

# Site URL
SITE_URL=https://weblancia.ma

# SMTP Configuration for form emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=hello@weblancia.ma
NOTIFICATION_EMAIL=hello@weblancia.ma

# WhatsApp Integration
WHATSAPP_NUMBER=+212XXXXXXXXX
WHATSAPP_ENABLED=false

# Google Analytics 4
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxx

# Microsoft Clarity
CLARITY_ID=xxxxxxxxxx

# JWT Secret (64+ chars random hex — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# ── Hostinger MySQL Database ──
# On Hostinger shared hosting, DB_HOST is usually "localhost" (same server).
# If your MySQL is on a separate Hostinger database server, use the internal IP from Hostinger panel.
# Do NOT use your site's public IP (41.248.118.14) — use localhost or the MySQL host from Hostinger panel.
DB_HOST=localhost
DB_USER=u539468682_weblancia
DB_PASSWORD=
DB_NAME=u539468682_weblancia
DB_PORT=3306

# Prisma connection URL (auto-derived from above — set explicitly if DB_HOST is not localhost)
DATABASE_URL="mysql://u539468682_weblancia:password@localhost:3306/u539468682_weblancia"
