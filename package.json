{
  "name": "weblancia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"try{require('fs').rmSync('.next/dev/cache',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "seed": "npx tsx prisma/seed.ts",
    "validate": "node scripts/validate-build.mjs",
    "validate:env": "node .env.validation.mjs",
    "validate:routes": "node scripts/validate-metadata.mjs",
    "validate:all": "npm run typecheck && npm run lint && npm run validate:routes && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/adapter-mariadb": "^7.8.0",
